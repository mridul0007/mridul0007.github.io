{
	"name": "SAC Maps Widget Combined",
	"imports": ["planning-model"],
	"description": "SAC Maps Widget Combined",
	"newInstancePrefix": "SAC_Maps_Widget_Combined",
	"eula": "",
	"vendor": "Contigo Consulting AG - MKoshy, JBuergmayr",
	"license": "",
	"id": "SAC_Maps_Widget_Combined",
	"version": "1.0.0",
	"icon": "",
	"webcomponents": [
		{
			"kind": "main",
			"tag": "com-example-combinedmaps",
			"url": "https://mridul0007.github.io/MapsWidget/maps.js", 
			"integrity": ""	,
			"ignoreIntegrity": true
			
		}		
	],
	"properties": {
		"google_mapsjs_api_key": {
			"type": "string"
		},
		"coordinate_master_data": {
			"type": "PlanningModelMember[]"
		}
		
	},
	"methods": {
		"set_google_mapsjs_api_key": {
			"description": "set google maps js api key",
            "parameters": [
