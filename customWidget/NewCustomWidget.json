{
	"name": "mycustomwidget",
	"imports": ["planning-model"],
	"description": "Hello World",
	"newInstancePrefix": "mycustomwidget",
	"eula": "",
	"vendor": "",
	"license": "",
	"id": "mycustomwidget",
	"version": "1.0.18",
	"icon": "",
	"webcomponents": [
		{
			"kind": "main",
			"tag": "custom-button",
			"url": "https://mridul0007.github.io/customWidget/Webcomponent.js",
			"integrity": "",
			"ignoreIntegrity": true
		}
	],
	"properties": {
		"dept": {
			"type": "string",
			"default": ""
		},
		"p_planningmodel": {
			"type": "PlanningModelMember"
		},
		"p_pmm": {
			"type": "PlanningModelMember"
		},
		"p_try":{
			"type" : "PLM_obj"
		}
	},
	"dataBindings": {
		"exportDataSource": {
		  "feeds": [
			{
			  "id": "dimensions",
			  "description": "The dimensions feed",
			  "type": "dimension"
			},
			{
			  "id": "measures",
			  "description": "The measures feed",
			  "type": "mainStructureMember"
			}
		  ]
		}
	  },
	  "types":{
		"PLM_obj":{
			"description" : "Object for PLM",
			"properties":[
				{
					"name" : "plm_operation",
					"type" : "string",
					"description" : "operation to do"
				},
				{
					"name" : "plm_PlanningModelMember",
					"type" : "PlanningModelMember",
					"description" : "operation to do"
				}
			]

		}
	  },
	"methods": {
		"clear": {
			"description": "Clear the resultset"
		},
		"setId": {
			"description": "id",
			"parameters": [
				{
					"name": "dept",
					"type": "string",
					"description": "dsad"
				}
			],
			"body": "this.dept = dept;"
		},
		"set_plan": {
			"description": "planningmodel object",
			"parameters": [
				{
					"name": "p_planningmodel",
					"type": "PlanningModelMember",
					"description": "dsad"
				}
			],
			"body": "this.p_planningmodel = p_planningmodel;"
		},
		"get_plan": {
			"returnType": "PlanningModelMember",
			"description": "planningmodel object",
			
			"body":  "return this.p_planningmodel;"
		},
		"set_p_pmm": {
			"description": "set p_pmm",
			"parameters": [
				{
					"name": "p_pmm",
					"type": "PlanningModelMember",
					"description": "PMM"
				}
			]
		},
		"get_p_pmm": {
			"returnType": "PlanningModelMember",
			"description": "pmm"
		},
		"set_p_try": {
			"description": "set set_plm_operation",
			"parameters": [
				{
					"name": "plm_operation",
					"type": "string",
					"description": "set set_plm_operation"
				}
			]
			
		},

		"get_p_try": {
			"returnType": "string",
			"description": "get get_plm_operation"
			
		}
	},
	"events": {
		"onClick": {
			"description": "Called when the user clicks the button."
		},
		"onSave": {
			"description": "Called when the user clicks the button."
		}
	}
	
}


