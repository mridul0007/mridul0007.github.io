{
	"name": "mycustomwidget",
	"imports": ["planning-model"],
	"description": "Hello World",
	"newInstancePrefix": "mycustomwidget",
	"eula": "",
	"vendor": "",
	"license": "",
	"id": "mycustomwidget",
	"version": "1.0.25",
	"icon": "",
	"webcomponents": [
		{
			"kind": "main",
			"tag": "custom-button",
			"url": "https://mridul0007.github.io/customWidget/Webcomponent.js",
			"integrity": "",
			"ignoreIntegrity": true
		}
	],
	"properties": {
		"p_plm_obj":{
			"type" : "PLM_obj"
		},
		"id":{
			"type" : "string"
		}
	},
	"dataBindings": {
		"exportDataSource": {
		  "feeds": [
			{
			  "id": "dimensions",
			  "description": "The dimensions feed",
			  "type": "dimension"
			},
			{
			  "id": "measures",
			  "description": "The measures feed",
			  "type": "mainStructureMember"
			}
		  ]
		}
	  },
	  "types":{
		"PLM_obj":{
			"description" : "Object for PLM",
			"properties":[
				{
					"name" : "plm_operation",
					"type" : "string",
					"description" : "operation to do"
				},
				{
					"name" : "plm_PlanningModelMember",
					"type" : "PlanningModelMember",
					"description" : "Planning model member"
				},
				{
					"name" : "status",
					"type" : "integer",
					"description" : "status"
				}
			]

		}
	  },
	"methods": {
		"clear": {
			"description": "Clear the resultset"
		},
		
		
		"set_p_plm_obj": {
			"description": "set set_plm_operation",
			"parameters": [
				{
					"name": "plm_object",
					"type": "PLM_obj",
					"description": "set PLM_obj"
				}
			],
			"body": "this.p_plm_obj = plm_object ;"
		},
		"get_p_plm_obj": {
			"returnType": "PLM_obj",
			"description": "get PLM_obj",
			"body": "return this.p_plm_obj;"
			
		},
		"set_id": {
			"description": "set set_plm_operation",
			"parameters": [
				{
					"name": "id",
					"type": "string",
					"description": "set member ID"
				}
			],
			"body": "this.id = id;"
			
		},

		"get_id": {
			"returnType": "string",
			"description": "get member ID",
			"body" : "return this.id;"
		}



	},
	"events": {
		"onClick": {
			"description": "Called when the user clicks the button."
		},
		"onSave": {
			"description": "Called when the user clicks the button."
		}
	}
	
}


