{
    "name": "textwidget",
    "id": "com.sap.custom.textwidget",
    "type": "widget",
    "description": "A custom text widget for SAP Analytics Cloud",
    "author": "Your Name",
    "version": "1.0.0",
    "icon": "",
    "defaultSize": {
        "width": 300,
        "height": 100
    },
    "properties": {
        "text": {
            "type": "string",
            "defaultValue": "Sample Text",
            "description": "The text to display in the widget"
        },
        "fontSize": {
            "type": "number",
            "defaultValue": 14,
            "description": "Font size of the text"
        },
        "textColor": {
            "type": "string",
            "defaultValue": "#000000",
            "description": "Color of the text"
        },
        "backgroundColor": {
            "type": "string",
            "defaultValue": "#FFFFFF",
            "description": "Background color of the widget"
        }
    },
    "events": {
        "onTextClick": {
            "description": "Triggered when the text is clicked"
        }
    }
}